{
  "manifest_version": 3,
  "name": "Gmail Scam Scanner",
  "version": "1.0.0",
  "description": "Scans your Gmail inbox for scam and phishing indicators using regex and AI-ready hooks.",

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Gmail Scam Scanner",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "identity",
    "storage"
  ],

  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://gmail.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "609275350798-sqbg2h307r993vnf8hj74eebrllkjibc.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
